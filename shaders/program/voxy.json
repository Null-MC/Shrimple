{
  "unusedString": "
    #include "/lib/constants.glsl"
    #include "/lib/common.glsl"
  ",
  "version": 1,
  "excludeLodsFromVanillaDepth": true,
  #ifdef DEFERRED_NORMAL_ENABLED
    #ifdef DEFERRED_SPECULAR_ENABLED
      "opaqueDrawBuffers": [0,4,2,3],
      "translucentDrawBuffers": [0,4,2,3],
    #else
      "opaqueDrawBuffers": [0,4,2],
      "translucentDrawBuffers": [0,4,2],
    #endif
  #else
    "opaqueDrawBuffers": [0],
    "translucentDrawBuffers": [0],
  #endif
  #ifdef TAA_ENABLED
    "taaOffset": "{return taa_offset;}",
  #endif
  "uniforms": [
    "cameraPosition",
    "cloudHeight",
    "cloudTime",
    "eyeBrightnessSmooth",
    "eyePosition",
    "fogColor",
    "fogEnd",
    "fogStart",
    "gbufferModelView",
    "gbufferModelViewInverse",
    "isEyeInWater",
    "rainStrength",
    "shadowLightPosition",
    "skyColor",
    "sunLocalDir",
    "taa_offset",
    "viewSize",
    "vxModelViewInv",
    "vxProjInv",
    "vxRenderDistance"
  ],
  "samplers": {
    #if LIGHTING_MODE == LIGHTING_MODE_ENHANCED && defined(WORLD_OVERWORLD)
      "texSkyTransmit": "sampler2D",
      "texSkyIrradiance": "sampler3D",
    #endif
    #ifdef SHADOW_CLOUDS
      "texCloudShadow": "sampler2D",
    #endif
    "lightmap": "sampler2D"
  }
}
