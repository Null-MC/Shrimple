{
  "unusedString": "
    #include "/lib/constants.glsl"
    #include "/lib/common.glsl"
  ",
  "version": 1,
  "excludeLodsFromVanillaDepth": true,
  #ifdef VELOCITY_ENABLED
    "opaqueDrawBuffers": [4,5,6,3],
  #else
    "opaqueDrawBuffers": [4,5,6],
  #endif
  #ifdef DEFERRED_ENABLED,
    #ifdef VELOCITY_ENABLED
      "translucentDrawBuffers": [1,4,5,6,3],
    #else
      "translucentDrawBuffers": [1,4,5,6],
    #endif
  #else
    #ifdef VELOCITY_ENABLED
      "translucentDrawBuffers": [1,2,3],
    #else
      "translucentDrawBuffers": [1,2],
    #endif
  #endif
  "blending": {
    -1: "off",
    0: "ONE ONE_MINUS_SRC_ALPHA ONE ONE"
  },
  #ifdef TAA_ENABLED
    "taaOffset": "{return taa_offset;}",
  #endif
  "useViewportDims": true,
  #if RENDER_SCALE == 3
    "renderScale": [0.25],
  #elif RENDER_SCALE == 2
    "renderScale": [0.50],
  #elif RENDER_SCALE == 1
    "renderScale": [0.75],
  #endif
  "uniforms": [
    "cameraPosition",
    "cloudHeight",
    "cloudTime",
    "eyeBrightnessSmooth",
    "eyePosition",
    "fogColor",
    "fogEnd",
    "fogStart",
    "frameTimeCounter",
    "gbufferModelView",
    "gbufferModelViewInverse",
    "gbufferProjectionInverse",
    "hasSkylight",
    "isEyeInWater",
    "rainStrength",
    "shadowLightPosition",
    "skyColor",
    "skyDayF",
    "sunLocalDir",
    "taa_offset",
    "viewSize",
    "viewSizeScaled",
    "vxModelViewInv",
    "vxProjInv",
    "vxRenderDistance",
    "weatherStrength",
    "weatherDensity"
  ],
  "samplers": {
    #if LIGHTING_MODE == LIGHTING_MODE_ENHANCED && defined(WORLD_OVERWORLD)
      "texSkyTransmit": "sampler2D",
      "texSkyIrradiance": "sampler3D",
    #endif
    #ifdef SHADOW_CLOUDS
      "texCloudShadow": "sampler2D",
    #endif
    "lightmap": "sampler2D",
    "depthtex0": "sampler2D"
  }
}
