{
  "unusedString": "
    #include "/lib/constants.glsl"
    #include "/lib/common.glsl"
  ",
  "version": 1,
  "excludeLodsFromVanillaDepth": true,
  #ifdef TAA_ENABLED
    #ifdef DEFERRED_ENABLED
      "opaqueDrawBuffers": [0,6,4,3],
      "translucentDrawBuffers": [1,2,6,4,3],
    #else
      "opaqueDrawBuffers": [0,6],
      "translucentDrawBuffers": [1,2,6],
    #endif
  #else
    #ifdef DEFERRED_ENABLED
      "opaqueDrawBuffers": [0,4,3],
      "translucentDrawBuffers": [1,2,4,3],
    #else
      "opaqueDrawBuffers": [0],
      "translucentDrawBuffers": [1,2],
    #endif
  #endif
  "blending": {
    #if LIGHTING_MODE == 1
      0: "ONE ONE_MINUS_SRC_ALPHA ONE ZERO",
      #ifdef TAA_ENABLED
        3: "off",
      #else
        2: "off",
      #endif
    #endif
    1: "off"
  },
  #ifdef TAA_ENABLED
    "taaOffset": "{return taa_offset;}",
  #endif
  "uniforms": [
    "cameraPosition",
    "cloudHeight",
    "cloudTime",
    "eyeBrightnessSmooth",
    "eyePosition",
    "fogColor",
    "fogEnd",
    "fogStart",
    "gbufferModelView",
    "gbufferModelViewInverse",
    "isEyeInWater",
    "rainStrength",
    "shadowLightPosition",
    "skyColor",
    "skyDayF",
    "sunLocalDir",
    "taa_offset",
    "viewSize",
    "vxModelViewInv",
    "vxProjInv",
    "vxRenderDistance",
    "weatherStrength",
    "weatherDensity"
  ],
  "samplers": {
    #if LIGHTING_MODE == LIGHTING_MODE_ENHANCED && defined(WORLD_OVERWORLD)
      "texSkyTransmit": "sampler2D",
      "texSkyIrradiance": "sampler3D",
    #endif
    #ifdef SHADOW_CLOUDS
      "texCloudShadow": "sampler2D",
    #endif
    #ifdef WATER_WAVE_ENABLED
      "colortex7": "sampler2D",
    #endif
    "lightmap": "sampler2D"
  }
}
